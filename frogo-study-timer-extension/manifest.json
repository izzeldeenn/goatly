{
  "name": "frogo | study timer",
  "version": "1.0.0",
  "description": "Study timer that works in the background while you study on any website",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "activeTab",
    "background",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://frogo-app.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "frogo | study timer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["auth.js", "popup.js", "popup.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
